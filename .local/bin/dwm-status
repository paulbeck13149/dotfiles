#!/bin/bash

get_cpu_and_temp() {
    echo -n "[CPU "
    # CPU bars
    cpu_usage=($(grep 'cpu[0-9]' /proc/stat | awk '{usage=($2+$4)*100/($2+$4+$5)} END {printf "%.0f ", usage}'))
    for usage in "${cpu_usage[@]}"; do
        echo -n "^c#ff0000^│^d^"
    done
    # Temperature in same bracket with comma
    temp=$(sensors | grep 'Core 0' | awk '{print $3}' | cut -c2-3)
    echo -n ", ${temp}°C]"
}

get_ram() {
    # Calculate percentage for RAM bar
    used=$(free | awk '/^Mem:/ {print $3}')
    total=$(free | awk '/^Mem:/ {print $2}')
    percent=$((used * 100 / total))
    
    # Create ASCII bar based on percentage
    if [ $percent -ge 75 ]; then
        bar="█▓▓░"
    elif [ $percent -ge 50 ]; then
        bar="█▓░░"
    elif [ $percent -ge 25 ]; then
        bar="█░░░"
    else
        bar="░░░░"
    fi
    
    ram_human=$(free -h | awk '/^Mem:/ {print $3}')
    echo -n "[RAM ${bar} ${ram_human}]"
}

get_processes() {
    procs=$(ps aux | wc -l)
    # Get just the 1-minute load average and format it to 2 decimal places
    load_avg=$(uptime | awk -F'load average:' '{print $2}' | awk '{printf "%.2f", $1}')
    echo -n "[↓${procs}, ↑${load_avg}]"
}

get_battery() {
    capacity=$(cat /sys/class/power_supply/BAT0/capacity)
    status=$(cat /sys/class/power_supply/BAT0/status)
    
    if [ "$status" = "Charging" ]; then
        color="#00ff00"
    elif [ $capacity -le 20 ]; then
        color="#ff0000"
    else
        color="#00ff00"
    fi
    
    # Smaller battery indicator with lighter background
    echo -n "^c#333333^[^d^^c$color^██^d^^c#333333^]^d^"  # Changed from ████ to ██ and #222222 to #333333
}

get_volume() {
    # Using pactl instead of amixer for more reliable volume control
    vol=$(pactl get-sink-volume @DEFAULT_SINK@ | awk '{print $5}' | tr -d '%' | head -n 1)
    echo -n "[VOL ${vol}%]"
}

get_datetime() {
    date +"[%a %b %d] [%H:%M]"
}

# Main status loop
while true; do
    xsetroot -name "$(get_cpu_and_temp) $(get_ram) $(get_processes) $(get_battery) $(get_volume) $(get_datetime)"
    sleep 2
done