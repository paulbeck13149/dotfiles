#!/bin/bash

get_cpu() {
    echo -n "[CPU "
    # Get CPU usage for each core
    cpu_usage=($(grep 'cpu[0-9]' /proc/stat | awk '{usage=($2+$4)*100/($2+$4+$5)} END {printf "%.0f ", usage}'))
    for usage in "${cpu_usage[@]}"; do
        echo -n "^c#ff0000^│^d^"
    done
    echo -n "]"
}

get_temp() {
    temp=$(sensors | grep 'Core 0' | awk '{print $3}' | cut -c2-3)
    echo -n "[TEMP ${temp}°C]"
}

get_ram() {
    ram=$(free -h | awk '/^Mem:/ {print $3}')
    echo -n "[RAM ${ram}]"
}

get_processes() {
    procs=$(ps aux | wc -l)
    load_avg=$(uptime | awk -F'load average:' '{print $2}' | awk -F', ' '{print $1","$2}' | tr -d ' ')
    echo -n "[↕${procs}, ↑${load_avg}]"
}

get_battery() {
    capacity=$(cat /sys/class/power_supply/BAT0/capacity)
    status=$(cat /sys/class/power_supply/BAT0/status)
    
    if [ "$status" = "Charging" ]; then
        color="#00ff00"
    elif [ $capacity -le 20 ]; then
        color="#ff0000"
    else
        color="#00ff00"
    fi
    
    echo -n "^c#222222^[^d^^c$color^━^d^^c#222222^]^d^"
}

get_volume() {
    vol=$(amixer get Master | awk -F'[][]' 'END{ print $2 }' | tr -d '%')
    echo -n "[VOL ${vol}%]"
}

get_datetime() {
    date +"[%a %b %d] [%H:%M]"
}

# Main status loop
while true; do
    xsetroot -name "$(get_cpu) $(get_temp) $(get_ram) $(get_processes) $(get_battery) $(get_volume) $(get_datetime)"
    sleep 2
done