#!/bin/sh

capacity=$(cat /sys/class/power_supply/BAT0/capacity)
status=$(cat /sys/class/power_supply/BAT0/status)

if [ "$status" = "Charging" ]; then
    color="#00ff00"
elif [ $capacity -le 20 ]; then
    color="#ff0000"
else
    color="#00ff00"
fi

# Calculate how much of the battery indicator should be filled
blocks=$((capacity * 2 / 100))  # 2 is total width of battery indicator
filled=""
empty=""

for i in $(seq 1 $blocks); do
    filled="${filled}█"
done

for i in $(seq 1 $((2 - blocks))); do
    empty="${empty}█"
done

echo "^c#333333^[^d^^c$color^${filled}^d^^c#333333^${empty}^d^^c#333333^]^d^"