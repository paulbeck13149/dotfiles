#!/bin/sh

capacity=$(cat /sys/class/power_supply/BAT0/capacity)
status=$(cat /sys/class/power_supply/BAT0/status)

# Determine color based on thresholds
if [ "$status" = "Charging" ]; then
    color="#00ff00"
elif [ $capacity -le 20 ]; then
    color="#ff0000"
elif [ $capacity -le 50 ]; then
    color="#ffff00"
else
    color="#00ff00"
fi

# Calculate width of filled portion (total width 20 pixels)
filled_width=$((capacity * 20 / 100))

# Draw battery using rectangles
# Format: ^r<width>x<height>+<xoffset>+<yoffset>^
echo "^c#333333^^r22x6+0+0^^f1^^c$color^^r${filled_width}x4+1+1^^f1^^c#333333^^r2x3+22+1.5^"