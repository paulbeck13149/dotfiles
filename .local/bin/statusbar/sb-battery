#!/bin/sh

capacity=$(cat /sys/class/power_supply/BAT0/capacity)
status=$(cat /sys/class/power_supply/BAT0/status)

# Determine color based on thresholds
if [ "$status" = "Charging" ]; then
    color="#00ff00"
elif [ $capacity -le 20 ]; then
    color="#ff0000"
elif [ $capacity -le 50 ]; then
    color="#ffff00"
else
    color="#00ff00"
fi

# Draw a smaller battery
# Main body 10x5 pixels, terminal 2x3 pixels
filled_width=$((capacity * 8 / 100))  # Scaled down from 20 to 8
echo "^c#333333^^r10x5+0+0^^f1^^c$color^^r${filled_width}x3+1+1^^f1^^c#333333^^r1x2+10+1.5^"