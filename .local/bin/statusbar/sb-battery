#!/bin/sh

capacity=$(cat /sys/class/power_supply/BAT0/capacity)
status=$(cat /sys/class/power_supply/BAT0/status)

# Determine color based on thresholds
if [ "$status" = "Charging" ]; then
    color="#00ff00"
elif [ $capacity -le 20 ]; then
    color="#ff0000"
elif [ $capacity -le 50 ]; then
    color="#ffff00"
else
    color="#00ff00"
fi

# Add spaces before and after the battery to prevent overlap
# Reduced size even further and added spacing
echo " ^c#333333^^r8x4+0+0^^f1^^c$color^^r$((capacity * 6 / 100))x2+1+1^^f1^^c#333333^^r1x2+8+1^ "