#!/bin/sh

# Get CPU usage for each core
cpu_usage=($(grep 'cpu[0-9]' /proc/stat | awk '{usage=($2+$4)*100/($2+$4+$5)} END {printf "%.0f ", usage}'))

# Start of CPU section
echo -n "[CPU "

# Map usage to block heights with color intensity
for usage in "${cpu_usage[@]}"; do
    if [ $usage -ge 90 ]; then
        echo -n "^c#ff0000^‚ñà^d^"        # Bright red for high load
    elif [ $usage -ge 70 ]; then
        echo -n "^c#ff3333^‚ñá^d^"        # Lighter red
    elif [ $usage -ge 50 ]; then
        echo -n "^c#ff6666^‚ñÖ^d^"        # Even lighter red
    elif [ $usage -ge 30 ]; then
        echo -n "^c#ff9999^‚ñÉ^d^"        # Very light red
    elif [ $usage -ge 10 ]; then
        echo -n "^c#ffcccc^‚ñÇ^d^"        # Barely red
    else
        echo -n "^c#fff0f0^‚ñÅ^d^"        # Almost white
    fi
done

# Add temperature
temp=$(sensors | grep 'Core 0' | awk '{print $3}' | cut -c2-3)
echo -n ", ${temp}¬∞C]"